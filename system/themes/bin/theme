#!/usr/bin/env bash
# Theme CLI: list, select, apply, current
set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles}"
THEMES_DIR="$DOTFILES_DIR/system/themes"
GENERATED_DIR="$THEMES_DIR/generated"
CURRENT_FILE="$GENERATED_DIR/.current-theme"

# shellcheck source=../../lib/log.sh
source "$DOTFILES_DIR/system/lib/log.sh"

usage() {
  cat <<'EOF'
Usage:
  theme list                  List available themes
  theme current               Show current theme name
  theme select [name]         Select theme interactively (fzf) or by name
  theme apply [name]          Apply theme (select if no name given)
EOF
}

_list() {
  for f in "$THEMES_DIR"/list/*.sh; do
    basename "$f" .sh
  done
}

_current() {
  if [[ -f "$CURRENT_FILE" ]]; then
    cat "$CURRENT_FILE"
  else
    echo "(none)"
  fi
}

_apply() {
  local theme_name="$1"
  local theme_file="$THEMES_DIR/list/${theme_name}.sh"

  if [[ ! -f "$theme_file" ]]; then
    log_error "Theme not found: $theme_name"
    echo "Available themes:"
    _list
    exit 1
  fi

  log_info "Applying theme: $theme_name"

  # 1. Source theme file (loads THEME_XX variables)
  # shellcheck disable=SC1090
  source "$theme_file"

  # 2. Ensure generated directory exists
  mkdir -p "$GENERATED_DIR"

  # 3. Run all renderers
  for renderer in "$THEMES_DIR"/renderers/*.sh; do
    log_step "Running renderer: $(basename "$renderer")"
    "$renderer"
  done

  # 4. Run borders renderer with --apply to restart borders process
  if [[ -f "$THEMES_DIR/renderers/borders.sh" ]]; then
    "$THEMES_DIR/renderers/borders.sh" --apply
  fi

  # 5. Persist current theme name
  echo "$theme_name" > "$CURRENT_FILE"

  # 6. Reload sketchybar
  if command -v sketchybar &>/dev/null; then
    log_step "Reloading sketchybar"
    sketchybar --reload 2>/dev/null || true
  fi

  # 8. Reload tmux
  if command -v tmux &>/dev/null && tmux has-session 2>/dev/null; then
    log_step "Reloading tmux colors"
    tmux source-file "$GENERATED_DIR/tmux-colors.conf" 2>/dev/null || true
  fi

  log_info "Theme '$theme_name' applied successfully"
}

_select() {
  if ! command -v fzf &>/dev/null; then
    log_error "fzf is required for theme selection"
    exit 1
  fi

  local theme_name
  theme_name=$(_list | fzf --height=40% --reverse --header="Select a theme" --prompt="Theme > ")

  if [[ -z "$theme_name" ]]; then
    log_warn "No theme selected"
    exit 0
  fi

  echo "$theme_name"
}

_cmd_select() {
  local name
  name=$(_select)
  [[ -n "$name" ]] && _apply "$name"
}

# Main
if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

case "$1" in
  list)
    _list
    ;;
  current)
    _current
    ;;
  select)
    if [[ $# -ge 2 ]]; then
      _apply "$2"
    else
      _cmd_select
    fi
    ;;
  apply)
    if [[ $# -ge 2 ]]; then
      _apply "$2"
    else
      _cmd_select
    fi
    ;;
  *)
    usage
    exit 1
    ;;
esac
