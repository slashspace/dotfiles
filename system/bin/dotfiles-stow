#!/usr/bin/env bash
# dotfiles stow — GNU Stow package manager with per-package target mapping
set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles}"

# shellcheck source=../../system/lib/log.sh
source "$DOTFILES_DIR/system/lib/log.sh"

# Package registry: "name:target"
CORE_PACKAGES=(
  "git:$HOME"
  "zsh:$HOME"
  "sheldon:$HOME/.config/sheldon"
  "tmux:$HOME/.config/tmux"
  "nvim:$HOME/.config/nvim"
  "starship:$HOME/.config/starship"
  "opencode:$HOME/.config/opencode"
  "bin:$HOME/.local/bin"
)

MACOS_PACKAGES=(
  "aerospace:$HOME/.config/aerospace"
  "ghostty:$HOME/.config/ghostty"
  "karabiner:$HOME/.config/karabiner"
  "sketchybar:$HOME/.config/sketchybar"
  "borders:$HOME/.config/borders"
)

usage() {
  cat <<'EOF'
Usage:
  dotfiles stow apply --core [--adopt]
  dotfiles stow apply --modules [--adopt]
  dotfiles stow apply --all [--adopt]
  dotfiles stow delete --core
  dotfiles stow delete --modules
  dotfiles stow delete --all
  dotfiles stow dry-run --core [--adopt]
  dotfiles stow dry-run --modules [--adopt]
  dotfiles stow dry-run --all [--adopt]

  --adopt  GNU stow --adopt: move blocking plain files into the package, then
           symlink. Typical fix when Karabiner replaced karabiner.json with a
           real file after an earlier stow.
EOF
}

_stow_packages() {
  local action="$1"   # stow or delete
  local flag="$2"     # -vn for dry-run, empty for real
  local adopt="$3"   # non-empty => pass stow --adopt (apply/dry-run only)
  local packages=()
  local failed=0

  case "$4" in
    --core)
      packages=("${CORE_PACKAGES[@]}")
      ;;
    --modules)
      packages=("${MACOS_PACKAGES[@]}")
      ;;
    --all)
      packages=("${CORE_PACKAGES[@]}" "${MACOS_PACKAGES[@]}")
      ;;
    *)
      usage
      exit 1
      ;;
  esac

  for entry in "${packages[@]}"; do
    local name="${entry%%:*}"
    local target="${entry#*:}"

    # Determine the stow dir based on which package this is
    local stow_dir=""
    if [[ "$name" == "bin" ]]; then
      stow_dir="$DOTFILES_DIR/system"
    else
      for c in "${CORE_PACKAGES[@]}"; do
        if [[ "$c" == "$name:"* ]]; then
          stow_dir="$DOTFILES_DIR/core"
          break
        fi
      done
      if [[ -z "$stow_dir" ]]; then
        stow_dir="$DOTFILES_DIR/modules"
      fi
    fi

    if [[ ! -d "$stow_dir/$name" ]]; then
      log_warn "Package directory not found: $stow_dir/$name"
      continue
    fi

    # Ensure target directory exists
    mkdir -p "$target"

    local stow_action="-S"
    if [[ "$action" == "delete" ]]; then
      stow_action="-D"
    fi

    local adopt_arg=""
    if [[ -n "$adopt" && "$action" == "stow" ]]; then
      adopt_arg="--adopt"
    fi

    log_step "$action $name -> $target"

    local output
    if ! output=$(stow --dir="$stow_dir" --target="$target" $stow_action $flag ${adopt_arg:+$adopt_arg} "$name" 2>&1); then
      log_error "Failed to $action $name: $output"
      if [[ "$output" == *conflicts* || "$output" == *CONFLICT* ]]; then
        log_warn "If a plain file blocks the symlink (common for karabiner.json), retry with: dotfiles stow $ACTION $SCOPE --adopt"
      fi
      failed=1
    fi
  done

  if [[ $failed -ne 0 ]]; then
    log_error "One or more packages failed to $action"
    return 1
  fi
}

if [[ $# -lt 2 ]]; then
  usage
  exit 1
fi

ACTION="$1"
shift

SCOPE=""
ADOPT=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --core | --modules | --all)
      SCOPE="$1"
      shift
      ;;
    --adopt)
      ADOPT=1
      shift
      ;;
    *)
      usage
      exit 1
      ;;
  esac
done

if [[ -z "$SCOPE" ]]; then
  usage
  exit 1
fi

FLAG=""
case "$ACTION" in
  apply)
    _stow_packages "stow" "" "$ADOPT" "$SCOPE"
    ;;
  delete)
    if [[ -n "$ADOPT" ]]; then
      log_warn "--adopt is ignored for delete"
    fi
    _stow_packages "delete" "" "" "$SCOPE"
    ;;
  dry-run)
    _stow_packages "stow" "-vn" "$ADOPT" "$SCOPE"
    ;;
  *)
    usage
    exit 1
    ;;
esac
