#!/usr/bin/env bash
# dotfiles modules — Install macOS modules
set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}"
source "$DOTFILES_DIR/system/lib/log.sh"
source "$DOTFILES_DIR/system/lib/platform.sh"

usage() {
  cat <<'EOF'
Usage:
  dotfiles modules install    Install and stow macOS-specific modules
EOF
}

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

case "$1" in
  install)
    log_info "Installing platform modules for $(platform_os)"

    if [[ "$(platform_os)" != "macos" ]]; then
      log_error "Only macOS is supported in this version"
      exit 1
    fi

    log_step "Stowing macOS modules"
    "$DOTFILES_DIR/system/bin/dotfiles-stow" apply --modules

    log_ok "macOS modules installed!"
    ;;
  *)
    usage
    exit 1
    ;;
esac
