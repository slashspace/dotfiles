[core]
  editor = nvim
  pager = bat --paging=always
[init]
  defaultBranch = main
[pull]
  rebase = true
[push]
  autoSetupRemote = true
[alias]
  s = status -s
  l = log --oneline --graph --all
  d = diff
  ds = diff --staged
[include]
  # Set your name and email in ~/.gitconfig.local
  path = ~/.gitconfig.local
[user]
	name = dingsheng
	email = dingsheng1214@gmail.com
