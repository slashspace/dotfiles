{
  // "plugin": ["oh-my-openagent@latest"],
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,

  // === 模型 ===
  "model": "opencode/kimi-k2.6", // 默认模型
  "small_model": "opencode/minimax-m2.5", // 标题生成等轻量级任务配置单独的模型

  // === 权限 ===
  "permission": {
    // .env reads without prompts
    "read": {
      ".env": "allow",
      ".env.*": "allow",
      ".env-*": "allow",
    },
    "external_directory": "allow",
    "bash": {
      "git add *": "deny",
      "git commit *": "deny",
      "git push *": "deny",
      "sudo *": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      ":(){:|:&};:": "deny",
    },
  },

  // === MCP Servers ===
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
    },
    // Docs lookup for libraries - https://context7.com
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
    // Web fetching - MCP official server (Python via uvx)
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch"],
    },
    // File system access (scoped to home directory)
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem"],
      "args": ["/Users/dingsheng"],
    },
    // GitHub integration
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "env": ["GITHUB_TOKEN"],
    },
    // Browser automation
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@executeautomation/playwright-mcp-server"],
    },
  },
}
